    DIVIDE          reduce using rule 22 (expression -> LPAREN expression RPAREN .)
    END             reduce using rule 22 (expression -> LPAREN expression RPAREN .)
    INTEGER         reduce using rule 22 (expression -> LPAREN expression RPAREN .)
    REAL            reduce using rule 22 (expression -> LPAREN expression RPAREN .)
    LOGICAL         reduce using rule 22 (expression -> LPAREN expression RPAREN .)
    ID              reduce using rule 22 (expression -> LPAREN expression RPAREN .)
    PRINT           reduce using rule 22 (expression -> LPAREN expression RPAREN .)
    RPAREN          reduce using rule 22 (expression -> LPAREN expression RPAREN .)
    COMMA           reduce using rule 22 (expression -> LPAREN expression RPAREN .)


state 45

    (14) print_list -> print_list COMMA . printable
    (16) printable -> . expression
    (17) printable -> . STRING
    (18) expression -> . expression PLUS expression
    (19) expression -> . expression MINUS expression
    (20) expression -> . expression TIMES expression
    (21) expression -> . expression DIVIDE expression
    (22) expression -> . LPAREN expression RPAREN
    (23) expression -> . NUMBER
    (24) expression -> . ID
    (25) expression -> . DOT_TRUE
    (26) expression -> . DOT_FALSE

    STRING          shift and go to state 39
    LPAREN          shift and go to state 24
    NUMBER          shift and go to state 25
    ID              shift and go to state 22
    DOT_TRUE        shift and go to state 26
    DOT_FALSE       shift and go to state 27

    printable                      shift and go to state 46
    expression                     shift and go to state 38

state 46

    (14) print_list -> print_list COMMA printable .

    COMMA           reduce using rule 14 (print_list -> print_list COMMA printable .)
    END             reduce using rule 14 (print_list -> print_list COMMA printable .)
    INTEGER         reduce using rule 14 (print_list -> print_list COMMA printable .)
    REAL            reduce using rule 14 (print_list -> print_list COMMA printable .)
    LOGICAL         reduce using rule 14 (print_list -> print_list COMMA printable .)
    ID              reduce using rule 14 (print_list -> print_list COMMA printable .)
    PRINT           reduce using rule 14 (print_list -> print_list COMMA printable .)

